# ==============================================================================
# SPYDER TRADING SYSTEM - ENVIRONMENT CONFIGURATION
# Tradier (Execution) + Polygon.io (Market Data)
# ==============================================================================

# ------------------------------------------------------------------------------
# TRADING CONFIGURATION
# ------------------------------------------------------------------------------
# Trading mode: sandbox (paper) or live (production)
# IMPORTANT: Always test in sandbox mode first!
TRADING_MODE=sandbox

# Safety confirmation for live trading
REQUIRE_LIVE_CONFIRMATION=true
LIVE_TRADING_CONFIRMED=false

# ------------------------------------------------------------------------------
# TRADIER BROKERAGE CONFIGURATION
# ------------------------------------------------------------------------------
# Get your API keys at: https://brokerage.tradier.com/
# 1. Create an account at Tradier
# 2. Go to API Access and generate an API token
# 3. Copy your Account ID from the dashboard

# Tradier API access token (Bearer token)
TRADIER_API_KEY=your_tradier_api_key_here

# Tradier account ID
TRADIER_ACCOUNT_ID=your_account_id_here

# Tradier API URLs (do not modify)
TRADIER_LIVE_URL=https://api.tradier.com/v1
TRADIER_SANDBOX_URL=https://sandbox.tradier.com/v1

# ------------------------------------------------------------------------------
# POLYGON.IO MARKET DATA CONFIGURATION
# ------------------------------------------------------------------------------
# Get your API key at: https://polygon.io/
# 1. Create an account at Polygon.io
# 2. Choose a plan (Starter plan works for development)
# 3. Copy your API key from the dashboard

# Polygon.io API key
POLYGON_API_KEY=your_polygon_api_key_here

# Polygon WebSocket and REST URLs (do not modify)
POLYGON_WS_URL=wss://socket.polygon.io/stocks
POLYGON_REST_URL=https://api.polygon.io

# Polygon data subscription settings
POLYGON_SUBSCRIBE_TRADES=true
POLYGON_SUBSCRIBE_QUOTES=true
POLYGON_SUBSCRIBE_AGGREGATES=true

# Default symbols to stream (comma-separated)
POLYGON_SYMBOLS=SPY,QQQ,IWM

# Polygon rate limit (Starter: 5/min, Business: 100/min)
POLYGON_RATE_LIMIT=5

# ------------------------------------------------------------------------------
# PROVIDER SELECTION
# ------------------------------------------------------------------------------
DATA_PROVIDER=polygon
EXECUTION_PROVIDER=tradier

# ------------------------------------------------------------------------------
# RISK MANAGEMENT
# ------------------------------------------------------------------------------
# Maximum position size (% of account)
MAX_POSITION_SIZE=0.10

# Maximum daily loss (% of account)
MAX_DAILY_LOSS=0.05

# Maximum number of open positions
MAX_OPEN_POSITIONS=5

# Emergency Override Password (CRITICAL SECURITY)
# Set a strong password for emergency override functionality
# NEVER use default passwords in production!
EMERGENCY_OVERRIDE_PASSWORD=your_secure_password_here

# ------------------------------------------------------------------------------
# LOGGING AND MONITORING
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/spyder.log
DEBUG_MODE=false

# GUI Dashboard Logging
# Minimum log level to display in dashboard widgets (DEBUG, INFO, WARNING, ERROR, CRITICAL)
GUI_LOG_LEVEL=INFO

# Prometheus metrics (optional)
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# ------------------------------------------------------------------------------
# NOTIFICATIONS (Optional)
# ------------------------------------------------------------------------------
# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email alerts
EMAIL_ADDRESS=
EMAIL_PASSWORD=
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ------------------------------------------------------------------------------
# SETUP INSTRUCTIONS
# ------------------------------------------------------------------------------
# 1. Copy this file to .env: cp .env.template .env
# 2. Fill in your Tradier and Polygon API credentials
# 3. Keep TRADING_MODE=sandbox until ready for live trading
# 4. Validate configuration: python SpyderQ_Scripts/validate_tradier_polygon.py
# 5. Run the system: python SpyderA_Core/SpyderA01_Main.py
#
# NEVER commit .env to git (it's in .gitignore)
