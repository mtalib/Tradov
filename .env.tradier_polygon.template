# ==============================================================================
# SPYDER TRADING SYSTEM - ENVIRONMENT CONFIGURATION
# Updated for Tradier + Polygon Migration
# ==============================================================================

# ------------------------------------------------------------------------------
# GENERAL CONFIGURATION
# ------------------------------------------------------------------------------
SPYDER_ENV=development
SPYDER_CONFIG_PATH=config/config.json
SPYDER_LOG_LEVEL=INFO
SPYDER_DB_PATH=data/spyder.db

# ------------------------------------------------------------------------------
# TRADING CONFIGURATION
# ------------------------------------------------------------------------------
# Trading mode: paper (sandbox) or live (production)
# IMPORTANT: Always test in paper mode first!
TRADING_MODE=paper

# ------------------------------------------------------------------------------
# TRADIER BROKERAGE CONFIGURATION
# ------------------------------------------------------------------------------
# Get your API keys at: https://brokerage.tradier.com/
# Tradier API access token (Bearer token)
TRADIER_API_KEY=your_tradier_api_key_here

# Tradier account ID
TRADIER_ACCOUNT_ID=your_account_id_here

# Tradier API URLs (automatically selected based on TRADING_MODE)
TRADIER_LIVE_URL=https://api.tradier.com/v1
TRADIER_SANDBOX_URL=https://sandbox.tradier.com/v1

# ------------------------------------------------------------------------------
# POLYGON.IO MARKET DATA CONFIGURATION
# ------------------------------------------------------------------------------
# Get your API key at: https://polygon.io/
# Polygon.io API key
POLYGON_API_KEY=your_polygon_api_key_here

# Polygon WebSocket and REST URLs
POLYGON_WS_URL=wss://socket.polygon.io/stocks
POLYGON_REST_URL=https://api.polygon.io

# Polygon data subscription settings
POLYGON_SUBSCRIBE_TRADES=true
POLYGON_SUBSCRIBE_QUOTES=false
POLYGON_SUBSCRIBE_AGGREGATES=true

# Default symbols to stream (comma-separated)
POLYGON_SYMBOLS=SPY,QQQ,VIX

# ------------------------------------------------------------------------------
# LEGACY IBKR CONFIGURATION (For Migration/Rollback)
# ------------------------------------------------------------------------------
# Keep these settings during migration phase for rollback capability
# Remove after successful migration to Tradier+Polygon

# IBKR OAuth Configuration (DEPRECATED - will be removed)
IBKR_CONSUMER_KEY=
IBKR_PRIVATE_KEY_PATH=
IBKR_ACCOUNT_ID=
IBKR_API_URL=https://api.ibkr.com/v1
IBKR_AUTH_METHOD=oauth

# IB Gateway Configuration (DEPRECATED - will be removed)
IB_GATEWAY_HOST=127.0.0.1
IB_GATEWAY_PORT=4002
IB_CLIENT_ID=1

# ------------------------------------------------------------------------------
# FEATURE FLAGS
# ------------------------------------------------------------------------------
# Enable/disable system features
ENABLE_LIVE_TRADING=false
ENABLE_RISK_MANAGEMENT=true
ENABLE_ML_PREDICTIONS=false
ENABLE_NOTIFICATIONS=true

# Data provider selection (tradier_polygon or ibkr)
DATA_PROVIDER=tradier_polygon
EXECUTION_PROVIDER=tradier_polygon

# ------------------------------------------------------------------------------
# MONITORING & OBSERVABILITY
# ------------------------------------------------------------------------------
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# Logging configuration
LOG_FILE_PATH=logs/spyder.log
LOG_ROTATION_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ------------------------------------------------------------------------------
# PERFORMANCE TUNING
# ------------------------------------------------------------------------------
# WebSocket reconnection settings
WS_RECONNECT_DELAY=5
WS_MAX_RECONNECT_ATTEMPTS=10

# HTTP request timeout (seconds)
HTTP_TIMEOUT=10

# Message buffer size
MESSAGE_BUFFER_SIZE=1000

# ------------------------------------------------------------------------------
# RISK MANAGEMENT
# ------------------------------------------------------------------------------
# Maximum position size (% of account)
MAX_POSITION_SIZE=0.10

# Maximum daily loss (% of account)
MAX_DAILY_LOSS=0.05

# Maximum number of open positions
MAX_OPEN_POSITIONS=5

# ------------------------------------------------------------------------------
# STRATEGY CONFIGURATION
# ------------------------------------------------------------------------------
# Default symbol for strategies
DEFAULT_SYMBOL=SPY

# Strategy execution interval (seconds)
STRATEGY_INTERVAL=1

# Minimum order size
MIN_ORDER_SIZE=1

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ------------------------------------------------------------------------------
DB_TYPE=sqlite
DB_NAME=spyder.db
DB_PATH=data/

# ------------------------------------------------------------------------------
# NOTIFICATION CONFIGURATION
# ------------------------------------------------------------------------------
# Slack webhook for alerts (optional)
SLACK_WEBHOOK_URL=

# Email notification settings (optional)
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# ------------------------------------------------------------------------------
# DEVELOPER SETTINGS
# ------------------------------------------------------------------------------
# Debug mode (verbose logging)
DEBUG_MODE=false

# Enable profiling
ENABLE_PROFILING=false

# Test mode (dry run, no actual orders)
TEST_MODE=true

# ------------------------------------------------------------------------------
# NOTES
# ------------------------------------------------------------------------------
# 1. Copy this file to .env and fill in your actual credentials
# 2. NEVER commit .env to git (it's in .gitignore)
# 3. Always start in paper/sandbox mode
# 4. Validate configuration with: python SpyderQ_Scripts/validate_tradier_polygon.py
# 5. See QUICK_START.md for setup instructions
