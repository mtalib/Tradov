# Spyder Trading System Configuration
# Copy this to .env and fill in your credentials

# IB Gateway Settings
IB_GATEWAY_PORT=4002  # 4002 for paper, 4001 for live
IB_CLIENT_ID=0

# Paper Trading Credentials
IB_PAPER_USER=your_username
IB_PAPER_PASS=your_password
IB_PAPER_ACCOUNT=your_paper_account

# Live Trading Credentials (be careful!)
IB_LIVE_USER=your_username
IB_LIVE_PASS=your_password
IB_LIVE_ACCOUNT=your_live_account

# Trading Mode
TRADING_MODE=paper  # 'paper' or 'live'

# Optional: Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_ADDRESS=
EMAIL_PASSWORD=
