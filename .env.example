# ==============================================================================
# SPYDER TRADING SYSTEM - Environment Configuration Template
# ==============================================================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual API keys and credentials
# 3. NEVER commit the .env file to git (it's in .gitignore)
# 4. Start with TRADING_MODE=sandbox for testing
#
# ==============================================================================

# ==============================================================================
# TRADIER API CONFIGURATION (Order Execution)
# ==============================================================================
# Get your API key from: https://brokerage.tradier.com/
# Navigate to: Account > API Access
TRADIER_API_KEY=your_tradier_api_key_here
TRADIER_ACCOUNT_ID=your_tradier_account_id_here

# Tradier URLs (usually don't need to change these)
TRADIER_SANDBOX_URL=https://sandbox.tradier.com/v1
TRADIER_LIVE_URL=https://api.tradier.com/v1

# ==============================================================================
# DATABENTO CONFIGURATION (Market Data — Primary)
# ==============================================================================
# Get your API key from: https://databento.com/
DATABENTO_API_KEY=your_databento_api_key_here

# Databento Subscription Settings
DATABENTO_DATASET=OPRA.PILLAR
DATABENTO_UNDERLYINGS=SPY
DATABENTO_SUBSCRIBE_TRADES=true
DATABENTO_SUBSCRIBE_QUOTES=true
DATABENTO_LIVE_SCHEMA=mbp-1
DATABENTO_HIST_SCHEMA=ohlcv-1h
DATABENTO_MAX_DAILY_GB=5
DATABENTO_WARN_GB=3

# ==============================================================================
# MASSIVE CONFIGURATION (Market Data — Secondary, Optional)
# ==============================================================================
MASSIVE_API_KEY=
MASSIVE_UNDERLYINGS=SPY
MASSIVE_STREAM_TRADES=true
MASSIVE_STREAM_QUOTES=true
MASSIVE_REST_RPS=5

# ==============================================================================
# TRADING MODE CONFIGURATION
# ==============================================================================
# CRITICAL: Always start with 'sandbox' for testing
# Options: sandbox, paper, live
TRADING_MODE=sandbox

# Data Provider (databento = primary, massive = secondary)
DATA_PROVIDER=databento

# Execution Provider (currently only tradier supported)
EXECUTION_PROVIDER=tradier

# ==============================================================================
# LIVE TRADING SAFETY
# ==============================================================================
# IMPORTANT: These settings prevent accidental live trading
# Set to 'true' only when you understand the risks
REQUIRE_LIVE_CONFIRMATION=true
LIVE_TRADING_CONFIRMED=false

# ==============================================================================
# ORDER CONFIRMATION SETTINGS
# ==============================================================================
# REQUIRE_LIVE_ORDER_CONFIRMATION: Development mode flag
#   - false (default): Autonomous operation, no blocking confirmation
#   - true: Development mode - ALL orders require confirmation before execution
REQUIRE_LIVE_ORDER_CONFIRMATION=false

# HIGH_RISK_ORDER_CONFIRMATION: Selective confirmation for exceptional orders
#   - true (default): Require confirmation for orders exceeding thresholds
#   - false: Fully autonomous, never require confirmation (use with caution)
HIGH_RISK_ORDER_CONFIRMATION=true

# HIGH_RISK_ORDER_THRESHOLD_USD: Dollar threshold for high-risk orders
#   - Orders >= this value require confirmation (if HIGH_RISK_ORDER_CONFIRMATION=true)
#   - Default: $50,000
HIGH_RISK_ORDER_THRESHOLD_USD=50000

# HIGH_RISK_ORDER_PORTFOLIO_PCT: Portfolio percentage threshold
#   - Orders >= this % of portfolio require confirmation
#   - Default: 0.25 (25% of portfolio)
HIGH_RISK_ORDER_PORTFOLIO_PCT=0.25

# AUTO_CONFIRM_HIGH_RISK_ORDERS: Testing/emergency override
#   - false (default): High-risk orders require actual user confirmation
#   - true: Auto-approve high-risk orders (TESTING ONLY - dangerous in production)
AUTO_CONFIRM_HIGH_RISK_ORDERS=false

# Trading Risk Limits
MAX_DAILY_TRADES=100
MAX_POSITION_SIZE=10000
MAX_DAILY_LOSS_USD=10000
EMERGENCY_STOP_LOSS_PCT=0.05

# ==============================================================================
# NOTIFICATIONS (Optional)
# ==============================================================================
# Telegram Bot (optional - for trade alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email Alerts (optional)
EMAIL_ADDRESS=
EMAIL_PASSWORD=
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ==============================================================================
# SYSTEM CONFIGURATION
# ==============================================================================
# Logging
LOG_LEVEL=INFO
GUI_LOG_LEVEL=INFO

# Debug Mode (set to true for detailed logging)
DEBUG_MODE=false

# ==============================================================================
# DATABASE (Optional - uses defaults if not set)
# ==============================================================================
# DATABASE_PATH=data/spyder.db

# ==============================================================================
# OLLAMA CONFIGURATION (Local LLM Agents)
# ==============================================================================
# Ollama base URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Model roles — set model names per role
OLLAMA_PRIMARY_MODEL=llama3.1:70b
OLLAMA_FAST_MODEL=llama3.1:8b
OLLAMA_CODE_MODEL=codestral:22b
OLLAMA_FINANCE_MODEL=llama3.1:70b

# Agent settings
OLLAMA_DEFAULT_TEMPERATURE=0.3
OLLAMA_TIMEOUT_SECONDS=120

# ==============================================================================
# ADVANCED SETTINGS (Usually don't need to change)
# ==============================================================================
# System Performance
# MAX_MEMORY_USAGE_MB=1024
# HEALTH_CHECK_INTERVAL=300

# ==============================================================================
# SETUP CHECKLIST
# ==============================================================================
# Before running Spyder, ensure you have:
# [ ] Created Tradier account at https://brokerage.tradier.com/
# [ ] Generated Tradier API key and noted account ID
# [ ] Created Databento account at https://databento.com/
# [ ] Generated Databento API key
# [ ] Copied this file to .env and filled in your keys
# [ ] Set TRADING_MODE=sandbox
# [ ] Run validation: python SpyderQ_Scripts/validate_configuration.py
# [ ] Run config test: python config/config.py
#
# ==============================================================================
